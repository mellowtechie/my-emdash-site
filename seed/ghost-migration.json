        "slug": "about",
        "content": [
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Mellow Techie is an independent publication launched in August 2025 by Todd Murray. If you subscribe today, you'll get full access to the website as well as email newsletters about new content when it's available. Your subscription makes this site possible, and allows Mellow Techie to continue to exist. Thank you!",
                "marks": []
              }
            ]
          },
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Access all areasBy signing up, you'll get access to the full archive of everything that's been published before and everything that's still to come. Your very own private library.",
                "marks": []
              }
            ]
          },
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Fresh content, deliveredStay up to date with new content sent straight to your inbox! No more worrying about whether you missed something because of a pesky algorithm or news feed.",
                "marks": []
              }
            ]
          },
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Meet people like youJoin a community of other subscribers who share the same interests.",
                "marks": []
              }
            ]
          },
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Start your own thingEnjoying the experience? Get started for free and set up your very own subscription business using Ghost, the same platform that powers this website.",
                "marks": []
              }
            ]
          }
        ],
