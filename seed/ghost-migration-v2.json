        "id": "ghost-post-1",
        "slug": "coming-soon",
        "status": "published",
        "data": {
          "title": "Coming soon",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "This is Mellow Techie, a brand new site by Todd Murray that's just getting started. Things will be up and running here shortly, but you can subscribe in the meantime if you'd like to stay up to date and receive emails when new content is published!"
                }
              ]
            }
          ],
          "excerpt": "",
          "featured_image": {
            "$media": {
              "url": "https://static.ghost.org/v4.0.0/images/feature-image.jpg",
              "alt": "Coming soon",
