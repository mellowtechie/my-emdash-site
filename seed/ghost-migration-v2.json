      {
        "id": "ghost-post-2",
        "slug": "about",
        "status": "published",
        "data": {
          "title": "About this site",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Mellow Techie is an independent publication launched in August 2025 by Todd Murray. If you subscribe today, you'll get full access to the website as well as email newsletters about new content when it's available. Your subscription makes this site possible, and allows Mellow Techie to continue to exist. Thank you!"
                }
              ]
            },
            {
              "_type": "block",
              "style": "h3",
              "children": [
                {
                  "_type": "span",
                  "text": "Access all areas"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "By signing up, you'll get access to the full archive of everything that's been published before and everything that's still to come. Your very own private library."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h3",
              "children": [
                {
                  "_type": "span",
                  "text": "Fresh content, delivered"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Stay up to date with new content sent straight to your inbox! No more worrying about whether you missed something because of a pesky algorithm or news feed."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h3",
              "children": [
                {
                  "_type": "span",
                  "text": "Meet people like you"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Join a community of other subscribers who share the same interests."
                }
              ]
            },
            {
              "_type": "block",
              "style": "h3",
              "children": [
                {
                  "_type": "span",
                  "text": "Start your own thing"
                }
              ]
            },
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Enjoying the experience? Get started for free and set up your very own subscription business using Ghost, the same platform that powers this website."
                }
              ]
            }
          ],
          "excerpt": ""
        },
